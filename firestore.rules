rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function organizerEmail() {
      return signedIn() && request.auth.token.email is string
        ? request.auth.token.email.lower()
        : '';
    }

    function hasOrganizerEmails(data) {
      return data.keys().hasAny(['organizerEmails'])
        && data.organizerEmails is list
        && data.organizerEmails.size() > 0;
    }

    function validTournamentStatus() {
      return request.resource.data.status in [
        'draft',
        'setup',
        'live',
        'completed',
      ];
    }

    function hasTournamentAccess(data) {
      return signedIn()
        && (
          data.organizerUid == request.auth.uid
          || (
            hasOrganizerEmails(data)
            && organizerEmail() in data.organizerEmails
          )
        );
    }

    function isTournamentOrganizer(tournamentId) {
      return hasTournamentAccess(
        get(/databases/$(database)/documents/tournaments/$(tournamentId)).data
      );
    }

    function getTournamentRole(tournamentId) {
      return get(/databases/$(database)/documents/tournaments/$(tournamentId)/roles/$(request.auth.uid));
    }

    function hasTournamentRoleByEmail(tournamentId, role) {
      return signedIn()
        && organizerEmail() != ''
        && exists(/databases/$(database)/documents/tournaments/$(tournamentId)/roles/$(organizerEmail()))
        && get(/databases/$(database)/documents/tournaments/$(tournamentId)/roles/$(organizerEmail())).data.role == role
        && get(/databases/$(database)/documents/tournaments/$(tournamentId)/roles/$(organizerEmail())).data.isActive == true;
    }

    function hasTournamentRole(tournamentId, role) {
      return signedIn()
        && (
          (
            exists(/databases/$(database)/documents/tournaments/$(tournamentId)/roles/$(request.auth.uid))
            && getTournamentRole(tournamentId).data.role == role
            && getTournamentRole(tournamentId).data.isActive == true
          )
          || hasTournamentRoleByEmail(tournamentId, role)
        );
    }

    function hasAnyTournamentRole(tournamentId) {
      return signedIn()
        && (
          (
            exists(/databases/$(database)/documents/tournaments/$(tournamentId)/roles/$(request.auth.uid))
            && getTournamentRole(tournamentId).data.isActive == true
          )
          || (
            organizerEmail() != ''
            && exists(/databases/$(database)/documents/tournaments/$(tournamentId)/roles/$(organizerEmail()))
            && get(/databases/$(database)/documents/tournaments/$(tournamentId)/roles/$(organizerEmail())).data.isActive == true
          )
        );
    }

    function isTournamentAssistant(tournamentId) {
      return isTournamentOrganizer(tournamentId)
        || hasTournamentRole(tournamentId, 'assistant');
    }

    function isTournamentReferee(tournamentId) {
      return hasTournamentRole(tournamentId, 'referee');
    }

    function isTournamentStaff(tournamentId) {
      return isTournamentOrganizer(tournamentId)
        || hasAnyTournamentRole(tournamentId);
    }

    function isPublicTournament(tournamentId) {
      return get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.isPublic == true;
    }

    function acceptsVolunteerReferees(tournamentId) {
      return get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.acceptingVolunteerReferees == true;
    }

    function isVolunteerRoleCreate(tournamentId, roleId) {
      return signedIn()
        && isPublicTournament(tournamentId)
        && acceptsVolunteerReferees(tournamentId)
        && roleId == request.auth.uid
        && organizerEmail() != ''
        && request.resource.data.keys().hasOnly([
          'userId',
          'email',
          'displayName',
          'role',
          'isActive',
          'assignmentSource',
          'assignedAt',
          'assignedBy',
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.email == organizerEmail()
        && request.resource.data.displayName is string
        && request.resource.data.role == 'referee'
        && request.resource.data.isActive == true
        && request.resource.data.assignmentSource == 'volunteer'
        && request.resource.data.assignedBy == request.auth.uid;
    }

    function canAssistantDeactivateVolunteerReferee(tournamentId) {
      return hasTournamentRole(tournamentId, 'assistant')
        && resource.data.role == 'referee'
        && resource.data.assignmentSource == 'volunteer'
        && resource.data.isActive == true
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.email == resource.data.email
        && request.resource.data.displayName == resource.data.displayName
        && request.resource.data.role == resource.data.role
        && request.resource.data.assignmentSource == resource.data.assignmentSource
        && request.resource.data.assignedBy == resource.data.assignedBy
        && request.resource.data.assignedAt == resource.data.assignedAt
        && request.resource.data.isActive == false;
    }

    function validOrganizerEmails() {
      return request.resource.data.organizerEmails is list
        && request.resource.data.organizerEmails.size() > 0;
    }

    function organizerEmailsValidForUpdate() {
      return !request.resource.data.keys().hasAny(['organizerEmails'])
        || validOrganizerEmails();
    }

    match /tournaments/{tournamentId} {
      allow create: if signedIn()
        && request.resource.data.organizerUid == request.auth.uid
        && validOrganizerEmails()
        && organizerEmail() in request.resource.data.organizerEmails
        && validTournamentStatus();
      allow read: if hasTournamentAccess(resource.data)
        || isTournamentStaff(tournamentId)
        || resource.data.isPublic == true;
      allow update: if hasTournamentAccess(resource.data)
        && request.resource.data.organizerUid == resource.data.organizerUid
        && organizerEmailsValidForUpdate()
        && validTournamentStatus();
      allow delete: if hasTournamentAccess(resource.data);

      match /roles/{roleId} {
        allow read: if isTournamentStaff(tournamentId);
        allow create: if isTournamentOrganizer(tournamentId)
          || isVolunteerRoleCreate(tournamentId, roleId);
        allow update: if isTournamentOrganizer(tournamentId)
          || canAssistantDeactivateVolunteerReferee(tournamentId);
        allow delete: if isTournamentOrganizer(tournamentId);
      }

      match /entries/{entryId} {
        allow read: if isTournamentStaff(tournamentId)
          || isPublicTournament(tournamentId);
        allow create, update, delete: if isTournamentOrganizer(tournamentId);
      }

      match /seedPlans/{categoryId} {
        function validSeedPlan() {
          return request.resource.data.keys().hasOnly([
            'tournamentId',
            'categoryId',
            'categoryName',
            'format',
            'seedEntryIds',
            'createdAt',
            'updatedAt',
          ])
            && request.resource.data.tournamentId == tournamentId
            && request.resource.data.categoryId == categoryId
            && request.resource.data.categoryName is string
            && request.resource.data.categoryName.size() > 0
            && request.resource.data.format in ['group', 'knockout']
            && request.resource.data.seedEntryIds is list
            && request.resource.data.seedEntryIds.size() >= 2;
        }

        allow read, delete: if isTournamentOrganizer(tournamentId);
        allow create, update: if isTournamentOrganizer(tournamentId)
          && validSeedPlan();
      }

      match /courts/{courtId} {
        function validCourt() {
          return request.resource.data.keys().hasOnly([
            'tournamentId',
            'code',
            'name',
            'status',
            'orderIndex',
            'note',
            'createdAt',
            'updatedAt',
          ])
            && request.resource.data.tournamentId == tournamentId
            && request.resource.data.code is string
            && request.resource.data.code.size() > 0
            && request.resource.data.name is string
            && request.resource.data.name.size() > 0
            && request.resource.data.status in ['available', 'unavailable']
            && request.resource.data.orderIndex is int
            && request.resource.data.note is string;
        }

        allow read: if isTournamentStaff(tournamentId)
          || isPublicTournament(tournamentId);
        allow delete: if isTournamentOrganizer(tournamentId);
        allow create, update: if isTournamentOrganizer(tournamentId)
          && validCourt();
      }

      match /matches/{matchId} {
        allow read: if isTournamentStaff(tournamentId)
          || isPublicTournament(tournamentId);
        allow create, delete: if isTournamentOrganizer(tournamentId);
        allow update: if isTournamentOrganizer(tournamentId)
          || isTournamentAssistant(tournamentId);
      }

      match /scoreSubmissions/{submissionId} {
        allow read: if isTournamentAssistant(tournamentId);
        allow create: if isTournamentStaff(tournamentId)
          && request.resource.data.matchId is string
          && request.resource.data.submittedByUserId == request.auth.uid
          && request.resource.data.approvalStatus == 'pending';
        allow update: if isTournamentAssistant(tournamentId)
          && request.resource.data.approvalStatus in ['approved', 'rejected'];
      }
    }

    match /categories/{categoryId} {
      allow create: if isTournamentOrganizer(request.resource.data.tournamentId);
      allow read: if isTournamentOrganizer(resource.data.tournamentId)
        || isTournamentAssistant(resource.data.tournamentId)
        || isPublicTournament(resource.data.tournamentId);
      allow update, delete: if isTournamentOrganizer(resource.data.tournamentId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
