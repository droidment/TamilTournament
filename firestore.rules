rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function organizerEmail() {
      return signedIn() && request.auth.token.email is string
        ? request.auth.token.email.lower()
        : '';
    }

    function hasOrganizerEmails(data) {
      return data.keys().hasAny(['organizerEmails'])
        && data.organizerEmails is list
        && data.organizerEmails.size() > 0;
    }

    function validTournamentStatus() {
      return request.resource.data.status in [
        'draft',
        'setup',
        'live',
        'completed',
      ];
    }

    function hasTournamentAccess(data) {
      return signedIn()
        && (
          data.organizerUid == request.auth.uid
          || (
            hasOrganizerEmails(data)
            && organizerEmail() in data.organizerEmails
          )
        );
    }

    function isTournamentOrganizer(tournamentId) {
      return hasTournamentAccess(
        get(/databases/$(database)/documents/tournaments/$(tournamentId)).data
      );
    }

    function validOrganizerEmails() {
      return request.resource.data.organizerEmails is list
        && request.resource.data.organizerEmails.size() > 0;
    }

    function organizerEmailsValidForUpdate() {
      return !request.resource.data.keys().hasAny(['organizerEmails'])
        || validOrganizerEmails();
    }

    match /tournaments/{tournamentId} {
      allow create: if signedIn()
        && request.resource.data.organizerUid == request.auth.uid
        && validOrganizerEmails()
        && organizerEmail() in request.resource.data.organizerEmails
        && validTournamentStatus();
      allow read: if hasTournamentAccess(resource.data);
      allow update: if hasTournamentAccess(resource.data)
        && request.resource.data.organizerUid == resource.data.organizerUid
        && organizerEmailsValidForUpdate()
        && validTournamentStatus();
      allow delete: if hasTournamentAccess(resource.data);

      match /entries/{entryId} {
        allow read, create, update, delete: if isTournamentOrganizer(tournamentId);
      }

      match /seedPlans/{categoryId} {
        function validSeedPlan() {
          return request.resource.data.keys().hasOnly([
            'tournamentId',
            'categoryId',
            'categoryName',
            'format',
            'seedEntryIds',
            'createdAt',
            'updatedAt',
          ])
            && request.resource.data.tournamentId == tournamentId
            && request.resource.data.categoryId == categoryId
            && request.resource.data.categoryName is string
            && request.resource.data.categoryName.size() > 0
            && request.resource.data.format in ['group', 'knockout']
            && request.resource.data.seedEntryIds is list
            && request.resource.data.seedEntryIds.size() >= 2;
        }

        allow read, delete: if isTournamentOrganizer(tournamentId);
        allow create, update: if isTournamentOrganizer(tournamentId)
          && validSeedPlan();
      }

      match /courts/{courtId} {
        function validCourt() {
          return request.resource.data.keys().hasOnly([
            'tournamentId',
            'code',
            'name',
            'status',
            'orderIndex',
            'note',
            'createdAt',
            'updatedAt',
          ])
            && request.resource.data.tournamentId == tournamentId
            && request.resource.data.code is string
            && request.resource.data.code.size() > 0
            && request.resource.data.name is string
            && request.resource.data.name.size() > 0
            && request.resource.data.status in ['available', 'unavailable']
            && request.resource.data.orderIndex is int
            && request.resource.data.note is string;
        }

        allow read, delete: if isTournamentOrganizer(tournamentId);
        allow create, update: if isTournamentOrganizer(tournamentId)
          && validCourt();
      }
    }

    match /categories/{categoryId} {
      allow create: if isTournamentOrganizer(request.resource.data.tournamentId);
      allow read, update, delete: if isTournamentOrganizer(resource.data.tournamentId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
